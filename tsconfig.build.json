{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.unit.test.ts",
    "**/*.integration.test.ts",
    "**/*.contract.test.ts",
    "**/*.e2e.test.ts",
    "src/__tests__/**",
    "src/**/__tests__/**"
  ]
}
