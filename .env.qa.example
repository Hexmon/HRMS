# QA backend configuration.
# Copy to .env.qa for local QA runs. Do not commit real secrets.

# ------------------------------------------------------------
# Runtime and QA ports
# ------------------------------------------------------------
PORT=3001
API_HOST_PORT=3101
LOG_LEVEL=info
HRMS_DATA_STORE=postgres
OUTBOX_WORKER_INTERVAL_MS=2000

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_HOST_PORT=55432
POSTGRES_DB=hrms_platform_qa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_TEST_DB=hrms_platform_test
DATABASE_URL=postgres://postgres:postgres@localhost:55432/hrms_platform_qa
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:55432/hrms_platform_test

# ------------------------------------------------------------
# Valkey
# ------------------------------------------------------------
VALKEY_HOST_PORT=56379
VALKEY_URL=redis://localhost:56379

# ------------------------------------------------------------
# Cloudinary object storage
# QA defaults to mock mode so tests do not need external credentials.
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=local-cloudinary-mock
CLOUDINARY_API_KEY=local-cloudinary-key
CLOUDINARY_API_SECRET=local-cloudinary-secret
CLOUDINARY_FOLDER=hawkaii-hrms-qa
CLOUDINARY_RESOURCE_TYPE=auto
CLOUDINARY_UPLOAD_TRANSFORMATION=q_auto:eco,f_auto
CLOUDINARY_MOCK_UPLOADS=true

# ------------------------------------------------------------
# Document compression
# ------------------------------------------------------------
PDF_COMPRESSION_ENABLED=false
PDF_COMPRESSION_BINARY=gs
PDF_COMPRESSION_QUALITY=ebook
PDF_COMPRESSION_MIN_BYTES=131072
PDF_COMPRESSION_TIMEOUT_MS=30000
PDF_COMPRESSION_FAIL_OPEN=true

# ------------------------------------------------------------
# Auth and cookies
# ------------------------------------------------------------
JWT_ACCESS_SECRET=local-qa-access-secret-change-me
JWT_REFRESH_SECRET=local-qa-refresh-secret-change-me
SESSION_COOKIE_NAME=hrms_qa_session
COOKIE_SECURE=false

# ------------------------------------------------------------
# Public URLs and CORS
# ------------------------------------------------------------
API_BASE_URL=http://localhost:3101
APP_URL=http://localhost:3101
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# Transactional email via Resend
# ------------------------------------------------------------
EMAIL_DELIVERY_PROVIDER=resend
EMAIL_DELIVERY_MODE=log
RESEND_API_KEY=
RESEND_FROM_EMAIL="Hawkaii HRMS <verify@example.test>"
RESEND_FROM_NAME=Hawkaii HRMS
RESEND_REPLY_TO_EMAIL=
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_RESEND_HOURLY_LIMIT=5
EMAIL_VERIFICATION_RESEND_DAILY_LIMIT=10

# ------------------------------------------------------------
# QA seed accounts
# ------------------------------------------------------------
LOCAL_DEMO_PASSWORD=LocalDev@123
SEED_DIRECTOR_EMAIL=director@example.test
SEED_REVIEWER_EMAIL=reviewer@example.test
SEED_EMPLOYEE_1_EMAIL=e1@example.test
SEED_EMPLOYEE_2_EMAIL=e2@example.test
SEED_EMPLOYEE_3_EMAIL=e3@example.test
SEED_FINANCE_MANAGER_EMAIL=finance@example.test
SEED_ALTERNATE_FINANCE_EMAIL=finance2@example.test
SEED_ADMIN_EMAIL=admin@example.test
SEED_AUDITOR_EMAIL=auditor@example.test
SEED_ASSET_MANAGER_EMAIL=assets@example.test
QA_SEED_HR_MANAGER_EMAIL=hrm@example.test
QA_SEED_NORMAL_MANAGER_EMAIL=manager@example.test
QA_SEED_UNAUTHORIZED_EMPLOYEE_EMAIL=unauthorized@example.test
QA_SEED_TIMESHEET_APPROVER_EMAIL=timesheet.approver@example.test
