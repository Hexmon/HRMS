# Hawkaii HRMS backend development env template
# Use this for hosted dev at https://dev-api.hawkaii.in.
# For local development, keep real values in untracked .env.local and replace hosted URLs/infra with local ones.
# Product/security defaults live in src/config/runtime-defaults.ts.
# Seed email defaults live in src/config/seed-identities.ts.
# Do not commit real secrets.

# Runtime / ports
NODE_ENV=production
APP_ENV=development
APP_VERSION=0.1.0
BUILD_SHA=replace-with-dev-git-sha
PORT=3001
API_HOST_PORT=3001
LOG_LEVEL=debug
HRMS_DATA_STORE=postgres
OUTBOX_WORKER_INTERVAL_MS=2000
TRUST_PROXY=true
OPENAPI_PUBLIC=true

# PostgreSQL
# POSTGRES_* values are used by Docker compose; DATABASE_URL is used by the API/worker.
POSTGRES_HOST_PORT=15432
POSTGRES_DB=hrms_platform_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-dev-postgres-password
POSTGRES_TEST_DB=hrms_platform_dev_test
DATABASE_URL=postgresql://replace-with-neon-dev-pooled-url?sslmode=require
TEST_DATABASE_URL=postgresql://replace-with-neon-dev-test-pooled-url?sslmode=require

# Valkey
VALKEY_HOST_PORT=16379
VALKEY_URL=redis://replace-with-render-dev-valkey:6379

# Auth and cookies
JWT_ACCESS_SECRET=replace-with-dev-access-secret
JWT_REFRESH_SECRET=replace-with-dev-refresh-secret
SESSION_COOKIE_NAME=hrms_dev_session
COOKIE_SECURE=true
LOCAL_DEMO_PASSWORD=LocalDev@123

# Public URLs / CORS
API_BASE_URL=https://dev-api.hawkaii.in
APP_URL=https://dev-api.hawkaii.in
FRONTEND_URL=https://dev.hawkaii.in
CORS_ALLOWED_ORIGINS=https://dev.hawkaii.in

# Cloudinary storage
CLOUDINARY_MOCK_UPLOADS=false
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=hawkaii-hrms/dev
CLOUDINARY_RESOURCE_TYPE=auto
CLOUDINARY_UPLOAD_TRANSFORMATION=q_auto:eco,f_auto

# Transactional email
# Keep disabled unless Resend is configured. Allowed values: send, log, disabled.
EMAIL_DELIVERY_PROVIDER=resend
EMAIL_DELIVERY_MODE=disabled
RESEND_API_KEY=
RESEND_FROM_EMAIL="Hawkaii HRMS Dev <verify@hawkaii.in>"
RESEND_FROM_NAME=Hawkaii HRMS Dev
RESEND_REPLY_TO_EMAIL=
RESEND_WEBHOOK_SECRET=
RESEND_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PUBLIC_MAX=60

# PDF compression runtime toggles
PDF_COMPRESSION_ENABLED=true
PDF_COMPRESSION_BINARY=gs
PDF_COMPRESSION_QUALITY=ebook
PDF_COMPRESSION_TIMEOUT_MS=30000
PDF_COMPRESSION_FAIL_OPEN=true
