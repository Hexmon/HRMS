# Hawkaii HRMS backend QA/UAT env template
# Use this for https://qa-api.hawkaii.in.
# Product/security defaults live in src/config/runtime-defaults.ts.
# Seed email defaults live in src/config/seed-identities.ts.
# Do not commit real secrets.

# Runtime / ports
NODE_ENV=production
APP_ENV=qa
APP_VERSION=0.1.0
BUILD_SHA=replace-with-qa-git-sha
PORT=3001
API_HOST_PORT=3101
LOG_LEVEL=info
HRMS_DATA_STORE=postgres
HRMS_SEED_IF_EMPTY=false
OUTBOX_WORKER_INTERVAL_MS=2000
TRUST_PROXY=true
OPENAPI_PUBLIC=true

# PostgreSQL
# POSTGRES_* values are used by Docker compose; DATABASE_URL is used by the API/worker.
POSTGRES_HOST_PORT=55432
POSTGRES_DB=hrms_platform_qa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-qa-postgres-password
POSTGRES_TEST_DB=hrms_platform_qa_test
DATABASE_URL=postgresql://replace-with-neon-qa-pooled-url?sslmode=require
TEST_DATABASE_URL=postgresql://replace-with-neon-qa-test-pooled-url?sslmode=require

# Valkey
VALKEY_HOST_PORT=56379
VALKEY_URL=redis://replace-with-render-qa-valkey:6379

# Auth and cookies
JWT_ACCESS_SECRET=replace-with-qa-access-secret
JWT_REFRESH_SECRET=replace-with-qa-refresh-secret
SESSION_COOKIE_NAME=hrms_qa_session
COOKIE_SECURE=true
LOCAL_DEMO_PASSWORD=LocalDev@123

# Public URLs / CORS
API_BASE_URL=https://qa-api.hawkaii.in
APP_URL=https://qa-api.hawkaii.in
FRONTEND_URL=https://qa.hawkaii.in
CORS_ALLOWED_ORIGINS=https://qa.hawkaii.in

# Cloudinary storage
CLOUDINARY_MOCK_UPLOADS=false
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=hawkaii-hrms/qa
CLOUDINARY_RESOURCE_TYPE=auto
CLOUDINARY_UPLOAD_TRANSFORMATION=q_auto:eco,f_auto

# Transactional email
# Keep disabled unless Resend is configured. Allowed values: send, log, disabled.
EMAIL_DELIVERY_PROVIDER=resend
EMAIL_DELIVERY_MODE=disabled
RESEND_API_KEY=
RESEND_FROM_EMAIL="Hawkaii HRMS QA <verify@hawkaii.in>"
RESEND_FROM_NAME=Hawkaii HRMS QA
RESEND_REPLY_TO_EMAIL=support@hawkaii.in
RESEND_WEBHOOK_SECRET=
RESEND_REQUEST_TIMEOUT_MS=5000
RESEND_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PUBLIC_MAX=60

# PDF compression runtime toggles
PDF_COMPRESSION_ENABLED=true
PDF_COMPRESSION_BINARY=gs
PDF_COMPRESSION_QUALITY=ebook
PDF_COMPRESSION_TIMEOUT_MS=30000
PDF_COMPRESSION_FAIL_OPEN=true
