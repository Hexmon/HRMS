# Hawkaii HRMS hosted production backend env template
# Use this for https://api.hawkaii.in on Render with Neon/Cloudinary/Resend.
# Do not commit real secrets.

NODE_ENV=production
APP_ENV=production
APP_VERSION=0.1.0
BUILD_SHA=replace-with-prod-git-sha
PORT=3001
LOG_LEVEL=info
HRMS_DATA_STORE=postgres
OUTBOX_WORKER_INTERVAL_MS=2000
TRUST_PROXY=true
OPENAPI_PUBLIC=false

DATABASE_URL=postgresql://replace-with-neon-prod-pooled-url?sslmode=require
VALKEY_URL=redis://replace-with-render-prod-valkey:6379

JWT_ACCESS_SECRET=replace-with-long-random-prod-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-prod-refresh-secret
SESSION_COOKIE_NAME=hrms_session
COOKIE_SECURE=true

API_BASE_URL=https://api.hawkaii.in
APP_URL=https://api.hawkaii.in
FRONTEND_URL=https://hawkaii.in
CORS_ALLOWED_ORIGINS=https://hawkaii.in

CLOUDINARY_MOCK_UPLOADS=false
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=hawkaii-hrms/prod
CLOUDINARY_RESOURCE_TYPE=auto
CLOUDINARY_UPLOAD_TRANSFORMATION=q_auto:eco,f_auto

EMAIL_DELIVERY_PROVIDER=resend
EMAIL_DELIVERY_MODE=send
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL="Hawkaii HRMS <verify@hawkaii.in>"
RESEND_FROM_NAME=Hawkaii HRMS
RESEND_REPLY_TO_EMAIL=support@hawkaii.in
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
RESEND_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PUBLIC_MAX=60

PDF_COMPRESSION_ENABLED=true
PDF_COMPRESSION_BINARY=gs
PDF_COMPRESSION_QUALITY=ebook
PDF_COMPRESSION_TIMEOUT_MS=30000
PDF_COMPRESSION_FAIL_OPEN=true
