PORT=3001
API_HOST_PORT=3001
LOG_LEVEL=info
POSTGRES_HOST_PORT=5432
VALKEY_HOST_PORT=6379
POSTGRES_DB=hrms_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://postgres:replace-with-strong-password@postgres:5432/hrms_platform
VALKEY_URL=redis://valkey:6379
OBJECT_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=hawkaii-hrms
CLOUDINARY_RESOURCE_TYPE=auto
CLOUDINARY_UPLOAD_TRANSFORMATION=q_auto:eco,f_auto
CLOUDINARY_MOCK_UPLOADS=false
MINIO_ENDPOINT=https://s3-compatible-storage.example.com
MINIO_PUBLIC_ENDPOINT=https://files.hrms.example.com
MINIO_ACCESS_KEY=replace-with-minio-access-key-only-if-provider-is-minio
MINIO_SECRET_KEY=replace-with-minio-secret-key-only-if-provider-is-minio
MINIO_BUCKET=hawkaii-hrms
MINIO_REGION=us-east-1
PDF_COMPRESSION_ENABLED=true
PDF_COMPRESSION_BINARY=gs
PDF_COMPRESSION_QUALITY=ebook
PDF_COMPRESSION_MIN_BYTES=131072
PDF_COMPRESSION_TIMEOUT_MS=30000
PDF_COMPRESSION_FAIL_OPEN=true
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-secret
SESSION_COOKIE_NAME=hrms_session
COOKIE_SECURE=true
HRMS_DATA_STORE=postgres
OUTBOX_WORKER_INTERVAL_MS=2000
API_BASE_URL=http://hawkaii-hrms-api:3001
APP_URL=https://api.hrms.example.com
FRONTEND_URL=https://hrms.example.com
EMAIL_DELIVERY_PROVIDER=resend
EMAIL_DELIVERY_MODE=send
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL="Hawkaii HRMS <verify@hrms.example.com>"
RESEND_FROM_NAME=Hawkaii HRMS
RESEND_REPLY_TO_EMAIL=support@hrms.example.com
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
RESEND_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_RESEND_HOURLY_LIMIT=5
EMAIL_VERIFICATION_RESEND_DAILY_LIMIT=10
CORS_ALLOWED_ORIGINS=https://hrms.example.com

# Optional only if local/demo seed scripts are intentionally run.
LOCAL_DEMO_PASSWORD=replace-with-local-only-demo-password
SEED_DIRECTOR_EMAIL=director@example.test
SEED_REVIEWER_EMAIL=reviewer@example.test
SEED_EMPLOYEE_1_EMAIL=e1@example.test
SEED_EMPLOYEE_2_EMAIL=e2@example.test
SEED_EMPLOYEE_3_EMAIL=e3@example.test
SEED_FINANCE_MANAGER_EMAIL=finance@example.test
SEED_ALTERNATE_FINANCE_EMAIL=finance2@example.test
SEED_ADMIN_EMAIL=admin@example.test
SEED_AUDITOR_EMAIL=auditor@example.test
SEED_ASSET_MANAGER_EMAIL=assets@example.test
